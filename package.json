{
  "name": "penge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n app,zero -c cyan,magenta \"pnpm dev:app\" \"pnpm dev:zero\"",
    "dev:app": "vite dev --host 0.0.0.0 --port 3000",
    "dev:zero": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenv -e .env -- sh -c 'mkdir -p .zero-cache && ZERO_LOG_LEVEL=${ZERO_LOG_LEVEL:-warn} ZERO_REPLICA_FILE=${ZERO_REPLICA_FILE:-.zero-cache/zero.db} exec zero-cache-dev'",
    "build": "NODE_EXTRA_CA_CERTS=.cert/localhost-cert.pem vite build",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "zero:generate": "drizzle-zero generate --output src/zero/schema.ts --format",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.73",
    "@better-auth/drizzle-adapter": "1.6.18",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-slot": "1.2.4",
    "@rocicorp/zero": "1.6.2",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/react-virtual": "3.14.3",
    "ai": "6.0.208",
    "better-auth": "1.6.18",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lodash-es": "^4.18.1",
    "lucide-react": "1.18.0",
    "postgres": "3.4.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "10.0.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.10",
    "drizzle-zero": "0.18.0",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  }
}
